!data/raw/biogrid/.gitkeep
!data/raw/chembl/.gitkeep
!data/processed/nodes/.gitkeep
!data/processed/edges/.gitkeep
!data/processed/relations/.gitkeep
runtime_logs/
src/**/__pycache__/
tests/**/__pycache__/
